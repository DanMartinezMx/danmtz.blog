---
import "../styles/index.css";

import { getCollection, getEntry, render } from "astro:content";
import { name, openGraph } from "spectre:globals";
import ProfilePicture from "../assets/pfp.png";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import ImageGlow from "../components/ImageGlow.astro";
import Layout from "../layouts/Layout.astro";

const [posts, about, workExperience, quickInfo, socials] = await Promise.all([
	getCollection("posts", (post) => post.data.draft !== true),
	getEntry("other", "about"),
	getCollection("workExperience"),
	getCollection("quickInfo"),
	getCollection("socials"),
]);

const { Content: About } = await render(about!);
---

<Layout
	title={openGraph.home.title || name}
	description={openGraph.home.description}
	pagefindIgnore
>
	<!-- LEFT SIDEBAR: Info + Socials -->
	<div class="layout-grid-left desktop-only" slot="left">
		<Card class="flex-col-card">
			<ImageGlow
				quality={100}
				width={120}
				height={120}
				src={ProfilePicture}
				alt="A purple, minimalist looking ghost."
				loading="eager"
			/>
			<h2>{name}</h2>
			<ul class="overview-list">
				{
					quickInfo.map((info) => (
						<li>
							<Icon
								type={info.data.icon.type}
								name={info.data.icon.name as any}
								width={24}
								height={24}
								class="glow-icon"
							/>
							<span>{info.data.text}</span>
						</li>
					))
				}
			</ul>
		</Card>
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="user"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Sobre mi</h2>
			</div>
			<div class="prose">
				<About />
			</div>

			<p></p>
			<h2 class="no-mt">Redes</h2>
			<ul class="overview-list">
				{
					socials.map((item) => (
						<li>
							<a
								href={item.data.link}
								target="_blank"
								class="socials-link"
							>
								<Icon
									type={item.data.icon.type}
									name={item.data.icon.name as any}
									width={24}
									height={24}
									class="glow-icon"
								/>
								<span>{item.data.text}</span>
							</a>
						</li>
					))
				}
			</ul>
		</Card>
	</div>

	<!-- CENTER: Posts -->
	<div class="layout-grid-center" slot="center">
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="rss"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Últimos Posts</h2>
			</div>
			<div class="content-container">
				{
					posts
						.sort(
							(a, b) =>
								b.data.createdAt.getTime() -
								a.data.createdAt.getTime(),
						)
						.slice(0, 10)
						.map((post) => (
							<a href={`/blog/${post.id}`} class="post-container">
								<div class="post-header">
									<h3>{post.data.title}</h3>
									<span class="post-date">
										{post.data.createdAt.toLocaleDateString()}
									</span>
								</div>
								<span>{post.data.description}</span>
							</a>
						))
				}
			</div>
		</Card>

		<!-- MOBILE ONLY: Collapsible About -->
		<div class="mobile-only">
			<Card>
				<details class="mobile-section">
					<summary>
						<Icon
							type="lucide"
							name="user"
							width={20}
							height={20}
							class="glow-icon"
						/>
						<span>Sobre mí</span>
					</summary>
					<div class="mobile-section-content">
						<div
							class="flex-col-card"
							style="align-items: center; margin-bottom: 1rem;"
						>
							<ImageGlow
								quality={100}
								width={80}
								height={80}
								src={ProfilePicture}
								alt="A purple, minimalist looking ghost."
								loading="lazy"
							/>
						</div>
						<ul class="overview-list">
							{
								quickInfo.map((info) => (
									<li>
										<Icon
											type={info.data.icon.type}
											name={info.data.icon.name as any}
											width={24}
											height={24}
											class="glow-icon"
										/>
										<span>{info.data.text}</span>
									</li>
								))
							}
						</ul>
						<div class="prose" style="margin-top: 1rem;">
							<About />
						</div>
						<h3 class="no-mt" style="margin-top: 1rem;">Redes</h3>
						<ul class="overview-list">
							{
								socials.map((item) => (
									<li>
										<a
											href={item.data.link}
											target="_blank"
											class="socials-link"
										>
											<Icon
												type={item.data.icon.type}
												name={
													item.data.icon.name as any
												}
												width={24}
												height={24}
												class="glow-icon"
											/>
											<span>{item.data.text}</span>
										</a>
									</li>
								))
							}
						</ul>
					</div>
				</details>
			</Card>

			<Card>
				<details class="mobile-section">
					<summary>
						<Icon
							type="lucide"
							name="briefcase-business"
							width={20}
							height={20}
							class="glow-icon"
						/>
						<span>Experiencia Laboral</span>
					</summary>
					<div class="mobile-section-content">
						<div class="work-experience-container">
							{
								workExperience.reverse().map((entry) => (
									<div class="work-experience-entry">
										<span class="work-experience-duration">
											{entry.data.duration}
										</span>
										<h3 class="work-experience-company">
											{entry.data.company}
										</h3>
										<span class="work-experience-role">
											{entry.data.title}
										</span>
										<p class="work-experience-desc">
											{entry.data.description}
										</p>
									</div>
								))
							}
						</div>
					</div>
				</details>
			</Card>
		</div>
	</div>

	<!-- RIGHT SIDEBAR: Work Experience + Future sections -->
	<div class="layout-grid-right desktop-only" slot="right">
		<Card>
			<div class="header-container">
				<Icon
					type="lucide"
					name="briefcase-business"
					width={24}
					height={24}
					class="glow-icon"
				/>
				<h2>Experiencia</h2>
			</div>
			<div class="work-experience-container">
				{
					workExperience.reverse().map((entry) => (
						<div class="work-experience-entry">
							<span class="work-experience-duration">
								{entry.data.duration}
							</span>
							<h3 class="work-experience-company">
								{entry.data.company}
							</h3>
							<span class="work-experience-role">
								{entry.data.title}
							</span>
							<p class="work-experience-desc">
								{entry.data.description}
							</p>
						</div>
					))
				}
			</div>
		</Card>
		<Card>
			<div class="header-container">
				<h2>Por ahora</h2>
			</div>
			<Icon
				type="lucide"
				name="gamepad-2"
				width={24}
				height={24}
				class="glow-icon"
			/>
			<h4>Jugando</h4>
			<p>Crimson Desert</p>
		</Card>

		<!-- Future sections go here -->
		<!--
		<Card>
			<div class="header-container">
				<Icon type="lucide" name="gamepad-2" width={24} height={24} class="glow-icon" />
				<h2>Jugando ahora</h2>
			</div>
			<p>Elden Ring: Nightreign</p>
		</Card>
		-->
	</div>
</Layout>
